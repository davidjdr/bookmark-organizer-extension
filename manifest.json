{
  "manifest_version": 3,
  "name": "Bookmark Organizer",
  "version": "3.0.0",
  "description": "Organiza y verifica marcadores: ordena por tipo, detecta enlaces rotos y redirecciones.",
  "permissions": ["bookmarks", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
